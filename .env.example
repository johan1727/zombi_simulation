# Copiar a .env.production (no versionado) con la URL real tras desplegar
# el relay (Plan 10 Task 4, docs/superpowers/plans/2026-07-19-plan-10-matchmaking-en-vivo.md).
# Sin esta variable, el cliente usa el relay local (ws://localhost:8787).
VITE_RELAY_URL=wss://tu-relay.onrender.com

# Igual que arriba, pero para el servidor de verificación de desafíos
# (Plan 17 Task 3, docs/superpowers/plans/2026-07-20-plan-17-anti-trampas.md).
# Sin esta variable, el cliente usa http://localhost:8788 (npm run verificar).
VITE_VERIFICAR_URL=https://tu-verificador.onrender.com
